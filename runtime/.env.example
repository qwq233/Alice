# ============================================================================
# Alice Runtime — 环境变量模板
#
# cp .env.example .env && nano .env
# pm2 start ecosystem.config.cjs --only alice-runtime
# ============================================================================


# ┌─────────────────────────────────────────────────────────────────────────┐
# │ 1. 必填 — 缺少任何一项 Alice 无法启动                                  │
# └─────────────────────────────────────────────────────────────────────────┘

# -- Telegram MTProto --------------------------------------------------------
# 从 https://my.telegram.org/apps 获取
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_PHONE=+8613800138000

# -- LLM（OpenAI 兼容 API）---------------------------------------------------
# OhMyGPT（推荐）/ OpenRouter / DeepSeek / 本地 Ollama 等均可
# OhMyGPT 聚合 200+ 模型，免翻墙，注册即用: https://www.ohmygpt.com
LLM_BASE_URL=https://api.ohmygpt.com/v1
LLM_API_KEY=sk-...
LLM_MODEL=gemini-2.5-flash-preview-05-20


# ┌─────────────────────────────────────────────────────────────────────────┐
# │ 2. 选填 — 增强功能，空值 = 禁用对应模块                                │
# └─────────────────────────────────────────────────────────────────────────┘

# -- 管理员 ------------------------------------------------------------------
# Telegram 用户 ID（数字）。用于系统线程路由（晨报/周报）和权限控制。
# TELEGRAM_ADMIN=123456

# -- Operator 频道 -----------------------------------------------------------
# Alice 发送内部系统消息的频道 graph ID（如 channel:123456789）。
# 未设置时从 TELEGRAM_ADMIN 自动推导。
# OPERATOR_CHANNEL_ID=channel:123456789

# -- LLM Fallback（备用 Provider）-------------------------------------------
# 主力 LLM 熔断后自动切换到备用。不设置则不启用 fallback。
# LLM_FALLBACK_BASE_URL=https://api.deepseek.com/v1
# LLM_FALLBACK_API_KEY=sk-...
# LLM_FALLBACK_MODEL=deepseek-chat

# -- Reflection 专用模型 -----------------------------------------------------
# 内省/话题聚类不面向用户，可用更便宜的模型（空 = 回退到 LLM_*）
# LLM_REFLECT_BASE_URL=
# LLM_REFLECT_API_KEY=
# LLM_REFLECT_MODEL=gemini-2.5-flash-preview-05-20

# -- 图片感知 Vision（ADR-88）------------------------------------------------
# OpenAI-compatible Vision API。空 VISION_MODEL = 禁用图片感知。
# 不设 BASE_URL/API_KEY 则回退到 LLM_BASE_URL / LLM_API_KEY。
# VISION_MODEL=gemini-2.0-flash-lite
# VISION_BASE_URL=
# VISION_API_KEY=
# VISION_MAX_PER_TICK=5

# -- WD14 Tagger（Vision fallback）-------------------------------------------
# Gemini 安全过滤器拦截时，降级到 WD Tagger 标签描述。
# 部署: https://github.com/LlmKira/wd14-tagger-server
# 默认 http://127.0.0.1:39100（pm2 自动拉起），不可用时自动降级，通常无需修改。
# WD_TAGGER_URL=http://127.0.0.1:39100

# -- 语音合成 TTS（ADR-88）---------------------------------------------------
# 后端：MiniMax T2A（音质双竞技场第一 + 情感控制 + 语气标签）
# 空 TTS_BASE_URL = 禁用语音。音频自动加入随机静音填充模拟呼吸间隔。
#
# 国内版:
#   TTS_BASE_URL=https://api.minimaxi.com
#   TTS_API_KEY=eyJ...（JWT，从 platform.minimaxi.com 获取）
#   TTS_GROUP_ID=17xxxxx
# 国际版:
#   TTS_BASE_URL=https://api.minimax.io
#   TTS_API_KEY=eyJ...（从 platform.minimax.io 获取）
#   TTS_GROUP_ID=17xxxxx
#
# 音色列表: https://platform.minimaxi.com/faq/system-voice-id
# TTS_BASE_URL=
# TTS_API_KEY=
# TTS_MODEL=speech-02-hd
# TTS_VOICE=
# TTS_GROUP_ID=

# -- 语音识别 ASR（ADR-119）--------------------------------------------------
# OpenAI /audio/transcriptions 兼容。空 = 禁用语音识别。
# ASR_BASE_URL=
# ASR_API_KEY=
# ASR_MODEL=whisper-1

# -- 外部知识搜索 Exa（ADR-117）----------------------------------------------
# use_browser_app 搜索 + URL 阅读。空 = 禁用 browse。
# EXA_API_KEY=

# -- 音乐 API（ADR-132 Wave 3）----------------------------------------------
# NeteaseCloudMusicApi 兼容端点。空 = 禁用音乐推荐。
# MUSIC_API_BASE_URL=

# -- YouTube Data API -------------------------------------------------------
# 用于视频搜索/信息查询。空 = 禁用。
# YOUTUBE_API_KEY=

# -- 动漫角色分类器（ADR-153）-----------------------------------------------
# AnimeIDF 分类服务。默认 http://127.0.0.1:39101（pm2 自动拉起），不可用时降级（全部通过）。
# ANIME_CLASSIFY_URL=http://127.0.0.1:39101

# -- OCR（PaddleOCR）-------------------------------------------------------
# 本地部署，无 API 费用。默认启用，设为 false 关闭。
# OCR_ENABLED=true
# OCR_MAX_PER_TICK=3
# OCR_MIN_CONFIDENCE=0.6

# -- 话题自动聚类（ADR-226）-------------------------------------------------
# CLUSTERING_ENABLED=true
# CLUSTERING_BUFFER_SIZE=30
# CLUSTERING_MAX_AGE_MS=300000
# CLUSTERING_MIN_MESSAGES=5
# CLUSTERING_MAX_AUTO_THREADS=3


# ┌─────────────────────────────────────────────────────────────────────────┐
# │ 3. 调参 — 有合理默认值，通常不需要修改                                  │
# └─────────────────────────────────────────────────────────────────────────┘

# -- 睡眠节律（ADR-225）------------------------------------------------------
# 安静窗口：Alice 在此时段进入 dormant 模式（本地小时，默认 23:00-07:00）
# QUIET_WINDOW_START=23
# QUIET_WINDOW_END=7
# THETA_DORMANT_API=0.15
# DORMANT_WAKE_TIER=150

# -- 唤醒模式（ADR-190）------------------------------------------------------
# WAKEUP_OFFLINE_THRESHOLD_S=600
# WAKEUP_GRADUATION_TICKS=10

# -- 时间与节奏 --------------------------------------------------------------
# DT_MIN_MS=1000
# DT_MAX_MS=300000
# KAPPA_T=1.0
# SNAPSHOT_INTERVAL_S=600
# TIMEZONE_OFFSET=8

# -- 探索保护 ExplorationGuard -----------------------------------------------
# EXPLORE_MAX_JOINS_PER_DAY=5
# EXPLORE_MAX_SEARCH_PER_HOUR=10
# EXPLORE_JOIN_COOLDOWN_MS=3600000
# EXPLORE_SEARCH_COOLDOWN_MS=300000
# EXPLORE_POST_JOIN_SEARCH_COOLDOWN_MS=1800000
# EXPLORE_SILENT_DURATION_S=600
# EXPLORE_APPRENTICE_DURATION_S=1800
# EXPLORE_APPRENTICE_MAX_MSGS=3
# EXPLORE_CB_THRESHOLD=3
# EXPLORE_CB_OPEN_MS=3600000

# -- 外围消息采集 Peripheral --------------------------------------------------
# PERIPHERAL_PER_CHANNEL_CAP=3
# PERIPHERAL_TOTAL_CAP=8
# PERIPHERAL_MIN_TEXT_LENGTH=15

# -- 行为微调 ----------------------------------------------------------------
# DESIRE_BOOST=0.15
# MOOD_NUDGE_SCALE=0.05

# -- 日志与诊断 --------------------------------------------------------------
# LOG_LEVEL=info
# ALICE_PROMPT_LOG=false
